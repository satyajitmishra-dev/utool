rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Checks if the logged-in user is an administrator
    function isAdmin() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionTier == 'admin');
    }

    // Helper: Checks if user owns the document
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ==========================================
    // 1. USER PROFILES
    // ==========================================
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // ==========================================
    // 2. USAGE LOGS & DAILY METRICS
    // ==========================================
    match /usage_logs/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // ==========================================
    // 3. BILLING & INVOICES
    // ==========================================
    match /billing_history/{invoiceId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false; // Server-only write access via Firebase Admin SDK
    }

    // ==========================================
    // 4. REVIEWS
    // ==========================================
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    // ==========================================
    // 5. SUPPORT TICKETS
    // ==========================================
    match /support_tickets/{ticketId} {
      allow create: if true; 
      allow read, update: if isAdmin() || (resource.data.uid != null && isOwner(resource.data.uid));
      allow delete: if isAdmin();
    }

    // ==========================================
    // 6. TOOL HELP-FEEDBACK
    // ==========================================
    match /tool_feedback/{feedbackId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ==========================================
    // 7. FEATURE REQUESTS (UPVOTES)
    // ==========================================
    match /feature_requests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null && 
                    request.resource.data.votes == resource.data.votes + 1 &&
                    request.resource.data.votedUids.hasAll(resource.data.votedUids);
      allow delete: if isAdmin();
    }
  }
}
